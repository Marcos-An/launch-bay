{
  "extends": "../tsconfig.app.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "../dist-electron",
    "noEmit": false,
    "rootDir": ".",
    "lib": ["ES2022"],
    "types": ["node"]
  },
  "include": ["./main.ts", "./paths.ts", "./platform.ts", "./runtime/**/*.ts", "./hermes/**/*.ts", "./config/**/*.ts"],
  "exclude": ["./runtime/**/*.test.ts", "./hermes/**/*.test.ts"]
}
